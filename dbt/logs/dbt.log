  create view "fin_data_db"."dbt_stg"."stg_null_casting__dbt_tmp"
    
    
  as (
    WITH testando as (
    SELECT *
    FROM "fin_data_db"."bronze"."precos_historicos_ativos_crypto"
),

null_clean as (
    SELECT *
    FROM testando
    WHERE 
        date IS NOT NULL AND
        open IS NOT NULL AND
        high IS NOT NULL AND
        low IS NOT NULL AND
        close IS NOT NULL AND
        volume IS NOT NULL AND
        dgt_crrnc_cd IS NOT NULL AND
        mrkt_cd IS NOT NULL
),

casting as (
    SELECT 
        CAST(date as TIMESTAMP), 
        open,
        high,
        low,
        close,
        volume,
        dgt_crrnc_cd,
        mrkt_cd 
     from null_clean
)

SELECT * FROM casting
  );
